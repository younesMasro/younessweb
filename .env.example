# Contact form delivery — used by src/app/api/contact/route.ts
# Where lead emails are sent. Defaults to younes.masroure@gmail.com if unset.
CONTACT_TO_EMAIL=younes.masroure@gmail.com

# Option A — SMTP (recommended, e.g. Gmail App Password, or any SMTP provider).
# If SMTP_HOST/SMTP_USER/SMTP_PASS are all set, SMTP is used first.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Option B — Resend (https://resend.com). Used only if SMTP is not configured.
RESEND_API_KEY=

# If neither SMTP nor Resend is configured, the form still submits
# successfully and the lead is logged to the server console instead of
# being emailed — it is never lost, and the page never crashes.

# WhatsApp number in international format, digits only, no "+" or spaces
# (e.g. 15551234567). Used by the floating support widget and the footer
# WhatsApp link. Leave empty to show the widget in a safe placeholder state.
NEXT_PUBLIC_WHATSAPP_NUMBER=
